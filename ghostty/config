# Ghostty configuration

# Font
font-family = "JetBrainsMono Nerd Font"
font-size = 14

# Theme
theme = "catppuccin-mocha"

# Window
window-padding-x = 8
window-padding-y = 8
window-decoration-style = transparent

# Shell integration
shell-integration = detect

# Cursor
cursor-style = bar
cursor-style-blink = true

# Scrollback
scrollback-limit = 10000

# Performance
vsync = true
